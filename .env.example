AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21

AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Chunking
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# Retrieval
BM25_TOP_K=5
FAISS_TOP_K=5
FAISS_FETCH_K=15
FAISS_MMR_LAMBDA=0.5
RERANK_TOP_N=3
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# Caching (optional Redis semantic cache — requires Redis Stack with RediSearch)
USE_SEMANTIC_CACHE=false
REDIS_URL=redis://localhost:6379
REDIS_CACHE_SCORE_THRESHOLD=0.95

# Evaluation (Ragas judge — Groq, free tier, no credit card required)
# Sign up at https://console.groq.com
GROQ_API_KEY=your_groq_api_key
GROQ_JUDGE_MODEL=llama-3.3-70b-versatile

# Evaluation embeddings (local, for the Answer Relevancy metric)
# ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
